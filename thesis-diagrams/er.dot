graph ER_Diet_System {
    graph [charset="UTF-8", rankdir=TB, ranksep=0.55, nodesep=0.3, splines=polyline, pad=0.1];
    node [fontname="Microsoft YaHei", fontsize=15, color="#444444", margin="0.16,0.1"];
    edge [fontname="Microsoft YaHei", fontsize=13, color="#666666"];

    用户 [shape=box, label="用户信息"];
    身体记录 [shape=box, label="身体记录信息"];
    饮食记录 [shape=box, label="饮食记录信息"];
    食物 [shape=box, label="食物信息"];
    食物分类 [shape=box, label="食物分类信息"];
    AI建议 [shape=box, label="AI建议信息"];

    账号信息 [shape=ellipse, label="账号/密码"];
    身体指标 [shape=ellipse, label="身高/体重/BMI/BMR"];
    记录属性 [shape=ellipse, label="日期/餐次/摄入量"];
    营养成分 [shape=ellipse, label="热量/蛋白质/脂肪/碳水"];
    AI属性 [shape=ellipse, label="建议类型/生成结果"];

    用户 -- 账号信息;
    用户 -- 身体指标;
    饮食记录 -- 记录属性;
    食物 -- 营养成分;
    AI建议 -- AI属性;

    拥有 [shape=diamond, label="拥有"];
    记录 [shape=diamond, label="记录"];
    引用 [shape=diamond, label="引用"];
    属于 [shape=diamond, label="属于"];
    生成 [shape=diamond, label="生成"];

    用户 -- 拥有 [label="1"];
    拥有 -- 身体记录 [label="n"];

    用户 -- 记录 [label="1"];
    记录 -- 饮食记录 [label="n"];

    食物 -- 引用 [label="1"];
    引用 -- 饮食记录 [label="n"];

    食物分类 -- 属于 [label="1"];
    属于 -- 食物 [label="n"];

    用户 -- 生成 [label="1"];
    生成 -- AI建议 [label="n"];

    身体记录 -- 饮食记录 [label="1:n", style=dashed, color="#999999"];
}
