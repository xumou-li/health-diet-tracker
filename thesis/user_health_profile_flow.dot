digraph HealthProfileFlow {
    graph [
        charset="UTF-8",
        rankdir=TB,
        splines=ortho,
        nodesep=0.45,
        ranksep="0.7 equally",
        fontname="Microsoft YaHei",
        bgcolor="white",
        pad=0.25
    ];

    node [
        fontname="Microsoft YaHei",
        fontsize=16,
        shape=box,
        style="rounded,solid",
        color="black",
        fontcolor="black",
        penwidth=1.8,
        margin="0.24,0.14"
    ];

    edge [
        fontname="Microsoft YaHei",
        fontsize=14,
        color="black",
        fontcolor="black",
        penwidth=1.6,
        arrowsize=0.75
    ];

    start [label="", shape=circle, width=0.34, fixedsize=true];
    end   [label="", shape=doublecircle, width=0.38, fixedsize=true];

    decision1 [label="是否已有账号?", shape=diamond, style="solid", width=2.0, height=1.0, fixedsize=true, margin="0.08,0.04"];
    login     [label="登录系统", width=2.6];
    register  [label="注册并初始化健康档案", width=3.3];
    snapshot1 [label="生成首条BodyRecord快照", width=3.3];
    merge1    [label="", shape=diamond, width=0.28, height=0.28, fixedsize=true, style="solid", margin="0,0"];

    edit      [label="修改身体档案", width=2.8];
    decision2 [label="关键字段变化?", shape=diamond, style="solid", width=2.0, height=1.0, fixedsize=true, margin="0.08,0.04"];
    calc      [label="重新计算健康指标", width=3.0];
    save      [label="直接保存", width=2.4];
    snapshot2 [label="生成新快照", width=2.6];
    merge2    [label="", shape=diamond, width=0.28, height=0.28, fixedsize=true, style="solid", margin="0,0"];

    { rank=same; login; register; }
    { rank=same; calc; save; }

    start -> decision1;

    decision1 -> login    [xlabel="是", minlen=1];
    decision1 -> register [xlabel="否", minlen=1];

    register -> snapshot1;
    login -> merge1;
    snapshot1 -> merge1;
    login -> snapshot1 [style=invis, weight=1];

    merge1 -> edit;
    edit -> decision2;

    decision2 -> calc [xlabel="是", minlen=1];
    decision2 -> save [xlabel="否", minlen=1];

    calc -> snapshot2;
    save -> merge2;
    snapshot2 -> merge2;
    save -> snapshot2 [style=invis, weight=1];

    merge2 -> end;
}
